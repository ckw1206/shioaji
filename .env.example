# Shioaji API Credentials
Shioaji_ID=
Shioaji_secret=

# Google Sheets
GOOGLE_SHEETS_ID=

# Optional: Custom path for Google service account credentials
# Defaults: ./creds.json (Windows) or ./shioaji/creds.json (Linux)
# CREDS_PATH=./path/to/your/creds.json

# Docker/cron scheduling (used by docker-compose.yml, not read by shioaji_sync.py directly)
# Cron expression for how often the sync runs inside the container. Default: 9am Mon-Fri.
# CRON_SCHEDULE=0 9 * * 1-5

# IANA timezone the container's cron clock uses to evaluate CRON_SCHEDULE. Default: Asia/Taipei.
# TZ=Asia/Taipei